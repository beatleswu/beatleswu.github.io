# Canonical list of environment variables required by docker-compose.prod.yml.
# Copy to /opt/go-odyssey/.env on the production host and fill in real values.
# NEVER commit a filled-in copy of this file. All values below are fake
# placeholders.

# --- Image identity (see deploy/build-manifest.json) ---
GO_ODYSSEY_IMAGE=go-odyssey-app:REPLACE_WITH_GIT_SHA

# --- Postgres ---
POSTGRES_USER=go
POSTGRES_PASSWORD=REPLACE_WITH_REAL_PASSWORD
POSTGRES_DB=go_odyssey

# --- Flask session ---
SECRET_KEY=REPLACE_WITH_REAL_SECRET

# --- Mail (Resend) ---
RESEND_API_KEY=REPLACE_WITH_REAL_KEY
MAIL_FROM=noreply@example.com
ADMIN_NOTIFY_EMAIL=admin@example.com
NEW_USER_NOTIFY_EMAIL=admin@example.com

# --- Cloudflare Turnstile ---
TURNSTILE_SITE_KEY=REPLACE_WITH_REAL_SITE_KEY
TURNSTILE_SECRET=REPLACE_WITH_REAL_SECRET

# --- Site ---
SITE_URL=https://example.com

# --- Google login / OpenAI ---
GOOGLE_CLIENT_ID=REPLACE_WITH_REAL_CLIENT_ID
OPENAI_API_KEY=REPLACE_WITH_REAL_KEY

# --- NewebPay ---
NEWEBPAY_MERCHANT_ID=REPLACE_WITH_REAL_ID
NEWEBPAY_HASH_KEY=REPLACE_WITH_REAL_KEY
NEWEBPAY_HASH_IV=REPLACE_WITH_REAL_IV
NEWEBPAY_TEST=1

# --- PayPal Subscriptions ---
PAYPAL_CLIENT_ID=REPLACE_WITH_REAL_CLIENT_ID
PAYPAL_SECRET=REPLACE_WITH_REAL_SECRET
PAYPAL_TEST=1
